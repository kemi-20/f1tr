# ===== AI / LLM (OpenAI-compatible) =====
# Works with OpenAI, DeepSeek, local Ollama/vLLM, etc.
# DeepSeek current model ids (as of 2026-06): deepseek-v4-flash (fast) / deepseek-v4-pro.
# (deepseek-chat / deepseek-reasoner are deprecated aliases, removed 2026-07-24.)
AI_API_BASE_URL=api.deepseek.com
AI_API_KEY=sk-xxx
AI_MODEL=deepseek-v4-flash

# ===== Xiaomi MiMo TTS =====
# sk- prefix  -> https://api.xiaomimimo.com/v1
# tp- prefix  -> https://token-plan-cn.xiaomimimo.com/v1
MIMO_API_BASE_URL=api.xiaomimimo.com
MIMO_API_KEY=sk-xxx
